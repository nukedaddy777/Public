<Window x:Class="AndysWpfWindowManager.WpfGenericUtility"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndysWpfWindowManager"
        mc:Ignorable="d" WindowStyle="None" 
        MouseDown="WpfGenericUtility_MouseDown" KeyDown="KeyPressed" MouseWheel="ScrollActivated"
        AllowDrop="True"  SizeToContent="WidthAndHeight"
        Title="Utility Window">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="AliceBlue" BorderBrush="Black" BorderThickness="2" CornerRadius="5" Padding="5">
        <Grid Background="#F0F0F0">
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="txtBoxTitle" FontSize="16" VerticalAlignment="Center" Margin="10,2,2,2"/>
                <StackPanel x:Name="stackPanel" Grid.Column="4" MaxHeight="20"
                 Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnMinimize" Content="___" Margin="5,0,5,0"
                 BorderBrush="Transparent" Background="Transparent" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="🗖" Margin="5,0,5,0"
             BorderBrush="Transparent" Background="Transparent" Click="BtnMaximize_Click"/>
                    <Button x:Name="BtnClose" Content="X" Margin="5,0,5,0"
             BorderBrush="Transparent" Background="Transparent" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
            <Frame Grid.Row="1"
                x:Name="UtilityContentFrame"
                NavigationUIVisibility="Hidden"
                VerticalContentAlignment="Stretch" 
                HorizontalAlignment="Stretch"/>
        </Grid>
    </Border>
</Window>
