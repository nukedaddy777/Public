<Page x:Class="AndysWpfWindowManager.PageTabDialogBar"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AndysWpfWindowManager"
      mc:Ignorable="d" 
      d:DesignHeight="100" d:DesignWidth="700"
      AllowDrop="True" KeyDown="KeyPressed" MouseWheel="ScrollActivated"
       Title="PageTabDialogUnit">
    <Border Background="#F0F0F0" BorderBrush="Black" BorderThickness="2" CornerRadius="5" Padding="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            <Frame Grid.Row="0"
             x:Name="ContentFrame"
             NavigationUIVisibility="Hidden"
             VerticalContentAlignment="Stretch" 
             HorizontalAlignment="Stretch"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnSubmit" FontSize="18" Grid.Column="1" Background="Green" Foreground="White" Click="Submit_Click">
                    Submit
                </Button>
                <Button FontSize="18" Grid.Column="3" Background="LightGray" Foreground="Black" Click="Cancel_Click">
                    Cancel
                </Button>
            </Grid>
        </Grid>
    </Border>
</Page>
