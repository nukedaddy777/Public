<Window x:Class="AndysWpfWindowManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndysWpfWindowManager"
           mc:Ignorable="d" WindowStyle="None"
          MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Title="MainWindow" Height="700" Width="1000">
        <!-- Do not forget to capture the Window MouseLeftButton above  -->
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="Black" BorderBrush="Black" BorderThickness="2" CornerRadius="5" Padding="5">
        <Grid Background="#F0F0F0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="27*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
             <!--   <Border Background="AntiqueWhite" BorderBrush="Black" BorderThickness="1" Margin="0,0,1,1">
                    <TextBlock VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <TextBlock.Background>
                            <ImageBrush ImageSource="c:/test/image.bmp" AlignmentX="Left" Stretch="Uniform"/>
                        </TextBlock.Background>
                    </TextBlock> 
                </Border> -->
                <TextBlock Grid.Column="1" FontSize="18" VerticalAlignment="Top" Margin="10,2,2,2"  >
                 Andy's Window Manager Testing
                </TextBlock>
                <StackPanel Grid.Column="4" MaxHeight="20" 
                     Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnMinimize" Content="__" Margin="5,0,5,0" FontWeight="Bold" FontFamily="Courier New"
                     BorderBrush="Transparent" Background="Transparent" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="🗖" Margin="5,0,5,0"  FontWeight="Bold" FontFamily="Courier New"
                 BorderBrush="Transparent" Background="Transparent" Click="BtnMaximize_Click"/>
                    <Button x:Name="BtnClose" Content="X" Margin="5,0,5,0"  FontWeight="Bold" FontFamily="Courier New"
                 BorderBrush="Transparent" Background="Transparent" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
            <!-- xaml above provides a window that allows customized controls for a titled window
                 xaml below is specific for test purposes-->
                <Frame x:Name="FrameTabContainer" Grid.Row="2" 
                NavigationUIVisibility="Hidden"
                VerticalContentAlignment="Stretch" 
                HorizontalAlignment="Stretch"/>
        </Grid>
    </Border>
</Window>
